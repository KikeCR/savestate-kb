# Copy this file to .env and fill in real values. .env is gitignored.

# Flask
SECRET_KEY=change-me-to-a-random-string
FLASK_ENV=development

# Postgres (used to build DATABASE_URL in docker-compose.yml)
POSTGRES_USER=savestate
POSTGRES_PASSWORD=savestate
POSTGRES_DB=savestate

# RAWG API (get a free key at https://rawg.io/apidocs)
RAWG_API_KEY=your-rawg-api-key-here
