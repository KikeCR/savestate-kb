# Copy this file to .env and fill in real values. .env is gitignored.

# Flask
SECRET_KEY=change-me-to-a-random-string
FLASK_ENV=development

# Postgres (used to build DATABASE_URL in docker-compose.yml)
POSTGRES_USER=savestate
POSTGRES_PASSWORD=savestate
POSTGRES_DB=savestate

# RAWG API (get a free key at https://rawg.io/apidocs)
RAWG_API_KEY=your-rawg-api-key-here

# AI recommendations — DeepSeek (primary) and Kimi/Moonshot (fallback).
# Both are optional: if unset, the /recommendations feature falls back to a
# pure retrieval ranking (no LLM call) automatically.

# Get a key at https://platform.deepseek.com/api_keys. Billing is prepaid —
# also set a balance/spend cap on their dashboard as a backstop alongside the
# app's own internal $1/month guard (DEEPSEEK_MONTHLY_BUDGET_USD below).
DEEPSEEK_API_KEY=
DEEPSEEK_MONTHLY_BUDGET_USD=1.0

# Get a key at https://platform.moonshot.ai/console/api-keys. Same advice on
# setting a spend cap on their dashboard as a backstop.
KIMI_API_KEY=
KIMI_MONTHLY_BUDGET_USD=1.0

# Email (welcome/password-reset/password-changed), sent via a Celery worker.
# Defaults point at the local Mailpit dev container — no real credentials
# needed; view sent mail at http://localhost:8025. Swap these for a real
# provider's SMTP relay (SendGrid, Mailgun, SES, etc.) in production.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM_ADDRESS=noreply@savestate.local
